# === ШАБЛОН КОНФИГУРАЦИИ ===
# Скопируйте этот файл в .env и заполните актуальными значениями

# --- Database Configuration ---
DB_NAME=geocoder
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_HOST=postgres
DB_PORT=5432

# --- API Keys ---
GEOCODE_API_KEY=your_api_key_here

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=default